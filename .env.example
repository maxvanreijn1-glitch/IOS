# Pooled connection URL used by the app at runtime (e.g. Neon pooler endpoint).
DATABASE_URL="postgresql://user:password@pooler-host/dbname?sslmode=require"

# Direct (non-pooled) connection URL used only by Prisma Migrate.
# Required when using a connection pooler (e.g. Neon) because advisory locks
# needed by `prisma migrate dev` are not supported over pooled connections.
# If unset, migrations fall back to DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://user:password@direct-host/dbname?sslmode=require"

# Resend API key for sending transactional emails (https://resend.com)
RESEND_API_KEY="re_..."

# The verified sender email address configured in your Resend account
EMAIL_FROM="noreply@yourdomain.com"

# Public base URL of your deployment (used to generate invite links in emails)
# No leading spaces. Must include the scheme (https://).
NEXT_PUBLIC_URL=https://yourdomain.com
